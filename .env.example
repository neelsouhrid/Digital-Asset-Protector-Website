# Copy this file to .env and fill in real values. .env is git-ignored.
# Anything with the VITE_ prefix is bundled into the client — only put
# publishable values (URL, anon key) there. Service role / API secrets
# must NOT be prefixed with VITE_.

# Supabase (client-readable)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (server-only — service role bypasses RLS, never expose)
SUPABASE_SERVICE_KEY=

# Gemini (server-only)
GEMINI_API_KEY=

# Cloudinary (server-only)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
